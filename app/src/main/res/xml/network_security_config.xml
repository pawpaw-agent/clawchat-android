<?xml version="1.0" encoding="utf-8"?>
<!-- ClawChat Network Security Configuration -->
<network-security-config>

    <!-- 默认禁止明文流量 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <!-- 信任用户安装的证书（用于调试） -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- 信任 OpenClaw Gateway 内置证书 -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- 局域网 Gateway IP -->
        <domain includeSubdomains="false">192.168.0.213</domain>
        
        <!-- 直接信任 raw 目录中的 Gateway 证书 -->
        <certificates src="@raw/openclaw_gateway" />
    </domain-config>

    <!-- 开发调试：允许用户安装的证书 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
