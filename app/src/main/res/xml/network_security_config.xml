<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Configuration for ClawChat -->
<network-security-config>
    <!-- 
        Security Policy:
        - Debug builds: Allow cleartext for local development
        - Release builds: Force TLS 1.3, certificate pinning
    -->

    <!-- Base configuration (applies to all domains) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Debug configuration (debug builds only) -->
    <debug-overrides>
        <trust-anchors>
            <!-- Trust user added CAs while debugging -->
            <certificates src="user" />
        </trust-anchors>
        
        <!-- Allow cleartext for local development -->
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="true">192.168.0.0/16</domain>
            <domain includeSubdomains="true">10.0.0.0/8</domain>
            <domain includeSubdomains="true">172.16.0.0/12</domain>
            <domain includeSubdomains="true">localhost</domain>
            <domain includeSubdomains="true">127.0.0.1</domain>
        </domain-config>
    </debug-overrides>

    <!-- Production domains with certificate pinning -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- OpenClaw Gateway -->
        <domain includeSubdomains="true">openclaw.ai</domain>
        <domain includeSubdomains="true">*.openclaw.ai</domain>
        
        <!-- Tailscale MagicDNS -->
        <domain includeSubdomains="true">*.ts.net</domain>
        
        <!-- Certificate pins (update with actual production certs) -->
        <pin-set expiration="2027-01-01">
            <!-- Primary pin -->
            <pin digest="SHA-256">REPLACE_WITH_PRODUCTION_CERT_HASH</pin>
            <!-- Backup pin -->
            <pin digest="SHA-256">REPLACE_WITH_BACKUP_CERT_HASH</pin>
        </pin-set>
    </domain-config>

    <!-- Local network configuration (for LAN connections) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>
        <domain includeSubdomains="true">*.local</domain>
    </domain-config>
</network-security-config>
