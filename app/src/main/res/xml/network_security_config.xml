<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Configuration for ClawChat -->
<network-security-config>

    <!-- Base configuration: allow cleartext for local dev, force TLS in release -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug overrides: trust user CAs for debugging -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!-- Local network: allow cleartext for LAN connections -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Private IP ranges for LAN -->
        <domain includeSubdomains="true">192.168.0.213</domain>
        <domain includeSubdomains="true">192.168.*</domain>
        <domain includeSubdomains="true">10.*</domain>
        <domain includeSubdomains="true">172.16.*</domain>
        <domain includeSubdomains="true">172.17.*</domain>
        <domain includeSubdomains="true">172.18.*</domain>
        <domain includeSubdomains="true">172.19.*</domain>
        <domain includeSubdomains="true">172.2*</domain>
        <domain includeSubdomains="true">172.30.*</domain>
        <domain includeSubdomains="true">172.31.*</domain>
        <domain includeSubdomains="true">*.local</domain>
    </domain-config>

    <!-- OpenClaw Gateway (TLS required) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">openclaw.ai</domain>
        <domain includeSubdomains="true">ts.net</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

</network-security-config>
